# ============================================================
# A股量化交易系统 - 环境变量配置模板
# ============================================================
# 使用方法：
#   1. 复制此文件为 .env  (Windows: copy .env.example .env)
#   2. 填入下方的真实 Token 和路径
#   3. .env 文件已在 .gitignore 中，不会被提交到 Git
#
# 优先级：环境变量 > config.yaml > 代码默认值
# 代码读取：通过 python-dotenv 在 config_loader.py 中自动加载
# ============================================================


# ------------------------------------------------------------
# 数据源 API Token（敏感信息，禁止提交！）
# ------------------------------------------------------------

# Tushare Pro API Token（可选，用于备用数据源）
# 注册地址：https://tushare.pro/register
# 获取方式：登录后 -> 个人主页 -> 接口TOKEN
TUSHARE_TOKEN=your_tushare_token_here

# Baostock 不需要 Token，免费使用
# Akshare 不需要 Token，免费使用


# ------------------------------------------------------------
# 日志配置
# ------------------------------------------------------------

# 日志级别：DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO


# ------------------------------------------------------------
# 路径配置（可选，覆盖 config.yaml 中的设置）
# ------------------------------------------------------------

# 数据存储路径（默认：data_store）
# 取消注释以覆盖默认值
# DATA_STORE_PATH=D:/quant_data

# 临时文件路径（默认：temp）
TEMP_PATH=temp

# 回测报告输出路径（默认：reports）
REPORT_PATH=reports


# ------------------------------------------------------------
# 通知配置（可选，用于实盘告警）
# ------------------------------------------------------------

# 钉钉机器人 Webhook（用于回测/实盘异常告警）
# DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx

# 企业微信机器人 Webhook
# WECHAT_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx

# 邮件告警（SMTP）
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_USER=your_email@qq.com
# SMTP_PASSWORD=your_smtp_auth_code
# ALERT_EMAIL=receiver@example.com


# ------------------------------------------------------------
# 数据库配置（可选，未来扩展用）
# ------------------------------------------------------------

# PostgreSQL（存储交易记录、绩效报表）
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=quant_trading
# DB_USER=postgres
# DB_PASSWORD=your_db_password

# Redis（缓存实时行情）
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
